{
  "name": "@mosredna/devports",
  "version": "1.0.0",
  "description": "List, open, and safely stop Node.js development servers on Windows and Linux.",
  "author": "MosrednA <k.gaaikema@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MosrednA/devports.git"
  },
  "homepage": "https://github.com/MosrednA/devports#readme",
  "bugs": {
    "url": "https://github.com/MosrednA/devports/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "devports": "./bin/devports.js",
    "devport": "./bin/devports.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "check": "npm run format:check && npm run lint && npm test",
    "clean": "node -e \"const fs=require('node:fs'); for (const path of ['dist','.test-dist']) fs.rmSync(path,{recursive:true,force:true})\"",
    "dev": "tsx src/cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test \".test-dist/**/*.test.js\"",
    "prepack": "npm run check"
  },
  "engines": {
    "node": ">=22"
  },
  "os": [
    "win32",
    "linux"
  ],
  "keywords": [
    "node",
    "ports",
    "windows",
    "linux",
    "wsl",
    "development",
    "cli"
  ],
  "dependencies": {
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.34.1"
  },
  "packageManager": "npm@11.13.0"
}
